{
  "version": 2,
  "outputDirectory": "dist/public",
  "buildCommand": "npm run build",
  "installCommand": "npm install --ignore-scripts",
  "framework": null,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
